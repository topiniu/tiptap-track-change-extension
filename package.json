{
  "name": "tiptap-track-change-extension",
  "version": "1.3.0",
  "description": "A track change extension for Tiptap 3.18.0, similar to revision mode in Microsoft Word.",
  "keywords": [
    "tiptap",
    "trackchange",
    "revision",
    "extension"
  ],
  "license": "MIT",
  "author": "topiniu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/topiniu/tiptap-track-change-extension.git"
  },
  "homepage": "https://github.com/topiniu/tiptap-track-change-extension#readme",
  "bugs": {
    "url": "https://github.com/topiniu/tiptap-track-change-extension/issues"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && rollup -c",
    "dev": "npm run clean && rollup -c -w",
    "demo": "vite --config demo/vite.config.js",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm publish",
    "release:patch": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "devDependencies": {
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-commonjs": "^24.0.1",
    "@tiptap/core": "3.18.0",
    "@tiptap/pm": "3.18.0",
    "@tiptap/starter-kit": "3.18.0",
    "rollup": "^3.17.3",
    "rollup-plugin-auto-external": "^2.0.0",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "rollup-plugin-typescript2": "^0.34.1",
    "typescript": "^4.9.5",
    "vite": "4.5.14"
  },
  "peerDependencies": {
    "@tiptap/core": "3.18.0",
    "@tiptap/pm": "3.18.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
